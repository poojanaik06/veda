PORT=8080
PUBLIC_API_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:3000

MONGO_URI=mongodb://127.0.0.1:27017/vedaai
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Default AI provider: OpenRouter's free model router.
# Paste only your OpenRouter key here. You can also swap LLM_MODEL for any
# specific free OpenRouter model ending in ":free".
OPENROUTER_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openrouter/free

# Optional generic fallback name. OPENROUTER_API_KEY is preferred if both exist.
LLM_API_KEY=
